{
  "version": 2,
  "buildCommand": "./vercel-build.sh",
  "outputDirectory": "apps/evolve/dist",
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1.js" },
    { "source": "/(.*)", "destination": "/apps/evolve/dist/index.html" }
  ]
  ,"routes": [
    { "src": "/(.*)", "dest": "apps/evolve/dist/$1" }
  ]
}
