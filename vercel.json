{
  "version": 2,
  "buildCommand": "./vercel-build.sh",
  "outputDirectory": "apps/evolve/dist",
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/(.*)", "dest": "apps/evolve/dist/$1" }
  ]
}